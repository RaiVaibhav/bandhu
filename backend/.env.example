# Copy this to .env and fill in real values as we reach the milestone that needs each one.

DATABASE_URL=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Langfuse — from your project's Settings > API Keys page.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Region-specific — check Settings > Project in the Langfuse dashboard for
# your exact host (US and EU cloud regions use different hosts).
LANGFUSE_HOST=https://cloud.langfuse.com

# Content-logging toggles — off by default on purpose (see app/config.py).
# Flip to true only if you deliberately want raw content in telemetry.
TELEMETRY_LOG_MESSAGE_CONTENT=false
TELEMETRY_LOG_RETRIEVAL_CONTENT=false
TELEMETRY_LOG_PROMPT_CONTENT=false
